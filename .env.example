# ============================================================
# BeerWalk — variables de entorno
# Copia este fichero a .env y ajusta los valores.
# La migración local -> Coolify es SOLO cambiar este fichero.
# ============================================================

# --- PocketBase ---
PB_ADMIN_EMAIL=admin@beerwalk.local
PB_ADMIN_PASSWORD=cambiame-por-favor-1234

# URL interna (entre contenedores). En Coolify normalmente igual.
POCKETBASE_URL_INTERNAL=http://pocketbase:8090

# --- OCR ---
OCR_LANG=es
MATCH_THRESHOLD=78

# --- Enriquecimiento web automático (opcional) ---
# La búsqueda usa la instancia SearxNG propia (sin API key). Si GEMINI_API_KEY
# está vacía, la feature se desactiva sola.
# Gemini (tier gratuito): https://aistudio.google.com/apikey
ENRICH_ENABLED=1
ENRICH_MIN_CONFIDENCE=0.85
ENRICH_MAX_ITEMS_PER_SCAN=5
GEMINI_API_KEY=
# Alias -latest: los modelos con versión fija dejan de aceptar usuarios nuevos
GEMINI_MODEL=gemini-flash-latest

# --- Refuerzo Gemini Vision (pipeline híbrido de lectura de pizarras) ---
# PaddleOCR siempre va primero (gratis, local); Vision solo entra si >40% de
# bloques quedan sin reconocer o la confianza media es baja. Auditable en la
# collection ocr_metrics y en GET /stats del servicio OCR.
VISION_ENABLED=1
VISION_UNMATCHED_RATIO=0.4
VISION_MIN_AVG_CONFIDENCE=0.75
# URL de SearxNG que ve el contenedor OCR (en Coolify puede cambiar)
SEARXNG_URL_INTERNAL=http://searxng:8080
# URL pública/base de la instancia SearxNG (para sus propios enlaces internos)
SEARXNG_BASE_URL=http://localhost:8888/

# --- LibreTranslate ---
LT_LOAD_ONLY=es,ca,en
LT_DISABLE_WEB_UI=false

# --- App Expo (se copian a app-expo/.env) ---
# En local: IP de tu ordenador en la red wifi (NO localhost, el móvil no la ve)
EXPO_PUBLIC_POCKETBASE_URL=http://192.168.1.50:8090
EXPO_PUBLIC_OCR_URL=http://192.168.1.50:8000
EXPO_PUBLIC_TRANSLATE_URL=http://192.168.1.50:5000
# En producción:
# EXPO_PUBLIC_POCKETBASE_URL=https://pb.beerwalk.app
# EXPO_PUBLIC_OCR_URL=https://ocr.beerwalk.app
# EXPO_PUBLIC_TRANSLATE_URL=https://translate.beerwalk.app
