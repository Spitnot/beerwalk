{
  "expo": {
    "name": "BeerWalk",
    "slug": "beerwalk",
    "version": "0.1.0",
    "scheme": "beerwalk",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": { "supportsTablet": false, "bundleIdentifier": "app.beerwalk" },
    "android": { "package": "app.beerwalk" },
    "plugins": [
      "expo-router",
      ["expo-camera", { "cameraPermission": "BeerWalk usa la cámara para escanear pizarras de cerveza." }],
      "expo-secure-store"
    ]
  }
}
